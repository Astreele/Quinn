# ==========================================
# Quinn Discord Bot - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# ---- Discord Bot Configuration ----
# Required: Your Discord bot token from Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Optional: Command prefix for message-based commands (default: $)
PREFIX=$

# Optional: Discord user ID of the bot owner (grants special permissions)
OWNER_ID=your_discord_user_id

# Optional: Discord application client ID (for slash command registration)
CLIENT_ID=your_client_id

# Optional: Set to "true" to register commands to a specific test guild
USE_TEST_GUILD=false

# Optional: Guild ID for test command registration (required if USE_TEST_GUILD=true)
TEST_GUILD_ID=your_test_guild_id

# ---- Database Configuration (Optional) ----
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Leave empty to run without database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quinn

# Optional: Enable SSL for database connection (default: false)
DB_SSL=false

# Optional: Database port for local connections (default: 5432)
DB_PORT=5432

# Optional: Database password for Docker setup
DB_PASSWORD=postgres

# Optional: Database username for Docker setup (default: postgres)
DB_USER=postgres

# ---- Node Environment ----
# Set to "production" for production, "development" for local dev
NODE_ENV=development
