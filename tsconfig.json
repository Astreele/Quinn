{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node20",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "moduleResolution": "nodenext"
  },
  "include": ["src/**/*", "db_integration/**/*"],
  "exclude": ["node_modules", "dist", "db_integration/migrations"]
}
